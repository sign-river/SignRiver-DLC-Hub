{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signriver.example/schemas/dlc-catalog-v1.json",
  "title": "SignRiver DLC Catalog Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_id", "game_id", "revision", "assets", "signature"],
  "properties": {
    "schema_version": {"const": 1},
    "catalog_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,100}$"},
    "game_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,100}$"},
    "revision": {"type": "integer", "minimum": 1},
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dlc_id", "asset_name", "size", "sha256", "min_game_version", "max_game_version", "distribution_authorized"],
        "properties": {
          "dlc_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,100}$"},
          "asset_name": {"type": "string", "minLength": 1, "maxLength": 255},
          "size": {"type": "integer", "minimum": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "min_game_version": {"type": ["string", "null"], "pattern": "^[0-9]+(\\.[0-9]+){1,3}$"},
          "max_game_version": {"type": ["string", "null"], "pattern": "^[0-9]+(\\.[0-9]+){1,3}$"},
          "distribution_authorized": {"type": "boolean"}
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "value"],
      "properties": {
        "key_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,100}$"},
        "value": {"type": "string", "pattern": "^[A-Za-z0-9_-]{40,256}$"}
      }
    }
  }
}
